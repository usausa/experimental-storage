<div class="fb-modal-backdrop" @onclick="OnClose"></div>
<div class="fb-modal meta-dialog" @onclick:stopPropagation>
    <div class="fb-modal-header">
        <span>Metadata – @FileName</span>
        <button class="btn-se-icon" @onclick="OnClose"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="fb-modal-body fb-modal-body-scroll">
        @if (loading)
        {
            <div class="fb-modal-loading">
                <div class="spinner-se spinner-se-lg" role="status"></div>
            </div>
        }
        else if (metadata is not null)
        {
            <div class="meta-section">
                <h4 class="meta-section-title">System</h4>
                <div class="meta-row"><span class="meta-label">Key</span><span class="meta-value">@metadata.Key</span></div>
                <div class="meta-row"><span class="meta-label">Content-Type</span><span class="meta-value">@metadata.ContentType</span></div>
                <div class="meta-row"><span class="meta-label">Size</span><span class="meta-value">@FormatBytes(metadata.ContentLength)</span></div>
                <div class="meta-row"><span class="meta-label">ETag</span><span class="meta-value">@metadata.ETag</span></div>
                <div class="meta-row"><span class="meta-label">Last Modified</span><span class="meta-value">@metadata.LastModified.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span></div>
                <div class="meta-row"><span class="meta-label">Storage Class</span><span class="meta-value">@metadata.StorageClass</span></div>
                <div class="meta-row"><span class="meta-label">ACL</span><span class="meta-value">@metadata.Acl</span></div>
                @if (metadata.VersionId is not null)
                {
                    <div class="meta-row"><span class="meta-label">Version ID</span><span class="meta-value meta-value-mono">@metadata.VersionId</span></div>
                }
            </div>

            <div class="meta-section">
                <div class="meta-section-header">
                    <h4 class="meta-section-title">User Metadata</h4>
                    <button class="btn-se-ghost btn-se-xs" @onclick="AddUserMeta">
                        <i class="bi bi-plus"></i> Add
                    </button>
                </div>
                @if (editUserMeta.Count == 0)
                {
                    <p class="meta-empty">No user metadata</p>
                }
                else
                {
                    @for (var i = 0; i < editUserMeta.Count; i++)
                    {
                        var index = i;
                        <div class="meta-edit-row">
                            <input type="text" class="meta-input" placeholder="Key" value="@editUserMeta[index].Key"
                                   @onchange="e => UpdateUserMetaKey(index, e)" />
                            <input type="text" class="meta-input" placeholder="Value" value="@editUserMeta[index].Value"
                                   @onchange="e => UpdateUserMetaValue(index, e)" />
                            <button class="btn-se-icon btn-se-icon-sm" @onclick="() => editUserMeta.RemoveAt(index)">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                }
            </div>

            <div class="meta-section">
                <div class="meta-section-header">
                    <h4 class="meta-section-title">Tags</h4>
                    <button class="btn-se-ghost btn-se-xs" @onclick="AddTag">
                        <i class="bi bi-plus"></i> Add
                    </button>
                </div>
                @if (editTags.Count == 0)
                {
                    <p class="meta-empty">No tags</p>
                }
                else
                {
                    @for (var i = 0; i < editTags.Count; i++)
                    {
                        var index = i;
                        <div class="meta-edit-row">
                            <input type="text" class="meta-input" placeholder="Key" value="@editTags[index].Key"
                                   @onchange="e => UpdateTagKey(index, e)" />
                            <input type="text" class="meta-input" placeholder="Value" value="@editTags[index].Value"
                                   @onchange="e => UpdateTagValue(index, e)" />
                            <button class="btn-se-icon btn-se-icon-sm" @onclick="() => editTags.RemoveAt(index)">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                }
            </div>

            @if (saveError is not null)
            {
                <p class="fb-modal-warn">@saveError</p>
            }
        }
    </div>
    <div class="fb-modal-footer">
        <button class="btn-se-ghost" @onclick="OnClose">Cancel</button>
        <button class="btn-se-primary" @onclick="SaveChanges" disabled="@saving">
            @if (saving)
            {
                <div class="spinner-se spinner-se-xs" role="status"></div>
            }
            Save
        </button>
    </div>
</div>
